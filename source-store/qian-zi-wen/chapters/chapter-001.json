{
  "chapter": {
    "character_count": 1000,
    "id": "chapter-001",
    "order": 1,
    "reading_unit_count": 125,
    "reading_units": [
      {
        "character_count": 8,
        "id": "chapter-001-line-001",
        "order": 1,
        "source_block_chunk": 1,
        "source_block_order": 1,
        "text": "天地玄黃　宇宙洪荒"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-002",
        "order": 2,
        "source_block_chunk": 1,
        "source_block_order": 2,
        "text": "日月盈昃　辰宿列張"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-003",
        "order": 3,
        "source_block_chunk": 1,
        "source_block_order": 3,
        "text": "寒來暑往　秋收冬藏"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-004",
        "order": 4,
        "source_block_chunk": 1,
        "source_block_order": 4,
        "text": "閏餘成歲　律召調陽"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-005",
        "order": 5,
        "source_block_chunk": 1,
        "source_block_order": 5,
        "text": "雲騰致雨　露結爲霜"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-006",
        "order": 6,
        "source_block_chunk": 1,
        "source_block_order": 6,
        "text": "金生麗水　玉出崑岡"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-007",
        "order": 7,
        "source_block_chunk": 1,
        "source_block_order": 7,
        "text": "劍號巨闕　珠稱夜光"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-008",
        "order": 8,
        "source_block_chunk": 1,
        "source_block_order": 8,
        "text": "果珍李柰　菜重芥薑"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-009",
        "order": 9,
        "source_block_chunk": 1,
        "source_block_order": 9,
        "text": "海鹹河淡　鱗潛羽翔"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-010",
        "order": 10,
        "source_block_chunk": 1,
        "source_block_order": 10,
        "text": "龍師火帝　鳥官人皇"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-011",
        "order": 11,
        "source_block_chunk": 1,
        "source_block_order": 11,
        "text": "始制文字　乃服衣裳"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-012",
        "order": 12,
        "source_block_chunk": 1,
        "source_block_order": 12,
        "text": "推位讓國　有虞陶唐"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-013",
        "order": 13,
        "source_block_chunk": 1,
        "source_block_order": 13,
        "text": "弔民伐罪　周發殷湯"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-014",
        "order": 14,
        "source_block_chunk": 1,
        "source_block_order": 14,
        "text": "坐朝問道　垂拱平章"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-015",
        "order": 15,
        "source_block_chunk": 1,
        "source_block_order": 15,
        "text": "愛育黎首　臣伏戎羌"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-016",
        "order": 16,
        "source_block_chunk": 1,
        "source_block_order": 16,
        "text": "遐邇壹體　率賓歸王"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-017",
        "order": 17,
        "source_block_chunk": 1,
        "source_block_order": 17,
        "text": "鳴鳳在樹　白駒食場"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-018",
        "order": 18,
        "source_block_chunk": 1,
        "source_block_order": 18,
        "text": "化被草木　賴及萬方"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-019",
        "order": 19,
        "source_block_chunk": 1,
        "source_block_order": 19,
        "text": "蓋此身髮　四大五常"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-020",
        "order": 20,
        "source_block_chunk": 1,
        "source_block_order": 20,
        "text": "恭惟鞠養　豈敢毀傷"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-021",
        "order": 21,
        "source_block_chunk": 1,
        "source_block_order": 21,
        "text": "女慕貞烈　男效才良"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-022",
        "order": 22,
        "source_block_chunk": 1,
        "source_block_order": 22,
        "text": "知過必改　得能莫忘"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-023",
        "order": 23,
        "source_block_chunk": 1,
        "source_block_order": 23,
        "text": "罔談彼短　靡恃己長"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-024",
        "order": 24,
        "source_block_chunk": 1,
        "source_block_order": 24,
        "text": "信使可覆　器欲難量"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-025",
        "order": 25,
        "source_block_chunk": 1,
        "source_block_order": 25,
        "text": "墨悲絲淬　詩讚羔羊"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-026",
        "order": 26,
        "source_block_chunk": 1,
        "source_block_order": 26,
        "text": "景行維賢　克念作聖"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-027",
        "order": 27,
        "source_block_chunk": 1,
        "source_block_order": 27,
        "text": "德建名立　形端表正"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-028",
        "order": 28,
        "source_block_chunk": 1,
        "source_block_order": 28,
        "text": "空谷傳聲　虛堂習聽"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-029",
        "order": 29,
        "source_block_chunk": 1,
        "source_block_order": 29,
        "text": "禍因惡積　福緣善慶"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-030",
        "order": 30,
        "source_block_chunk": 1,
        "source_block_order": 30,
        "text": "尺璧非寶　寸陰是競"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-031",
        "order": 31,
        "source_block_chunk": 1,
        "source_block_order": 31,
        "text": "資父事君　曰嚴與敬"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-032",
        "order": 32,
        "source_block_chunk": 1,
        "source_block_order": 32,
        "text": "孝當竭力　忠則盡命"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-033",
        "order": 33,
        "source_block_chunk": 1,
        "source_block_order": 33,
        "text": "臨深履薄　夙興溫凊"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-034",
        "order": 34,
        "source_block_chunk": 1,
        "source_block_order": 34,
        "text": "似蘭斯馨　如松之盛"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-035",
        "order": 35,
        "source_block_chunk": 1,
        "source_block_order": 35,
        "text": "川流不息　淵澄取映"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-036",
        "order": 36,
        "source_block_chunk": 1,
        "source_block_order": 36,
        "text": "容止若思　言辭安定"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-037",
        "order": 37,
        "source_block_chunk": 1,
        "source_block_order": 37,
        "text": "篤初誠美　慎終宜令"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-038",
        "order": 38,
        "source_block_chunk": 1,
        "source_block_order": 38,
        "text": "榮業所基　籍甚無竟"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-039",
        "order": 39,
        "source_block_chunk": 1,
        "source_block_order": 39,
        "text": "學優登仕　攝職從政"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-040",
        "order": 40,
        "source_block_chunk": 1,
        "source_block_order": 40,
        "text": "存以甘棠　去而益詠"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-041",
        "order": 41,
        "source_block_chunk": 1,
        "source_block_order": 41,
        "text": "樂殊貴賤　禮別尊卑"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-042",
        "order": 42,
        "source_block_chunk": 1,
        "source_block_order": 42,
        "text": "上和下睦　夫唱婦隨"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-043",
        "order": 43,
        "source_block_chunk": 1,
        "source_block_order": 43,
        "text": "外受傅訓　入奉母儀"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-044",
        "order": 44,
        "source_block_chunk": 1,
        "source_block_order": 44,
        "text": "諸姑伯叔　猶子比兒"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-045",
        "order": 45,
        "source_block_chunk": 1,
        "source_block_order": 45,
        "text": "孔懷兄弟　同氣連枝"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-046",
        "order": 46,
        "source_block_chunk": 1,
        "source_block_order": 46,
        "text": "交友投分　切磨箴規"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-047",
        "order": 47,
        "source_block_chunk": 1,
        "source_block_order": 47,
        "text": "仁慈隱惻　造次弗離"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-048",
        "order": 48,
        "source_block_chunk": 1,
        "source_block_order": 48,
        "text": "節義廉退　顛沛匪虧"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-049",
        "order": 49,
        "source_block_chunk": 1,
        "source_block_order": 49,
        "text": "性靜情逸　心動神疲"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-050",
        "order": 50,
        "source_block_chunk": 1,
        "source_block_order": 50,
        "text": "守眞志滿　逐物意移"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-051",
        "order": 51,
        "source_block_chunk": 1,
        "source_block_order": 51,
        "text": "堅持雅操　好爵自縻"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-052",
        "order": 52,
        "source_block_chunk": 1,
        "source_block_order": 52,
        "text": "都邑華夏　東西二京"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-053",
        "order": 53,
        "source_block_chunk": 1,
        "source_block_order": 53,
        "text": "背邙面洛　浮渭據涇"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-054",
        "order": 54,
        "source_block_chunk": 1,
        "source_block_order": 54,
        "text": "宮殿盤鬱　樓觀飛驚"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-055",
        "order": 55,
        "source_block_chunk": 1,
        "source_block_order": 55,
        "text": "圖寫禽獸　畫彩仙靈"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-056",
        "order": 56,
        "source_block_chunk": 1,
        "source_block_order": 56,
        "text": "丙舍傍啟　甲帳對楹"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-057",
        "order": 57,
        "source_block_chunk": 1,
        "source_block_order": 57,
        "text": "肆筵設席　鼓瑟吹笙"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-058",
        "order": 58,
        "source_block_chunk": 1,
        "source_block_order": 58,
        "text": "升階納陛　弁轉疑星"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-059",
        "order": 59,
        "source_block_chunk": 1,
        "source_block_order": 59,
        "text": "右通廣內　左達承明"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-060",
        "order": 60,
        "source_block_chunk": 1,
        "source_block_order": 60,
        "text": "既集墳典　亦聚群英"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-061",
        "order": 61,
        "source_block_chunk": 1,
        "source_block_order": 61,
        "text": "杜稾鍾隸　漆書壁經"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-062",
        "order": 62,
        "source_block_chunk": 1,
        "source_block_order": 62,
        "text": "府羅將相　路俠槐卿"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-063",
        "order": 63,
        "source_block_chunk": 1,
        "source_block_order": 63,
        "text": "戶封八縣　家給千兵"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-064",
        "order": 64,
        "source_block_chunk": 1,
        "source_block_order": 64,
        "text": "高冠陪輦　驅轂振纓"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-065",
        "order": 65,
        "source_block_chunk": 1,
        "source_block_order": 65,
        "text": "世祿侈富　車駕肥輕"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-066",
        "order": 66,
        "source_block_chunk": 1,
        "source_block_order": 66,
        "text": "策功茂實　勒碑刻銘"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-067",
        "order": 67,
        "source_block_chunk": 1,
        "source_block_order": 67,
        "text": "磻溪伊尹　佐時阿衡"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-068",
        "order": 68,
        "source_block_chunk": 1,
        "source_block_order": 68,
        "text": "奄宅曲阜　微旦孰營"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-069",
        "order": 69,
        "source_block_chunk": 1,
        "source_block_order": 69,
        "text": "桓公匡合　濟弱扶傾"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-070",
        "order": 70,
        "source_block_chunk": 1,
        "source_block_order": 70,
        "text": "綺迴漢惠　說感武丁"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-071",
        "order": 71,
        "source_block_chunk": 1,
        "source_block_order": 71,
        "text": "俊乂密勿　多士寔寧"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-072",
        "order": 72,
        "source_block_chunk": 1,
        "source_block_order": 72,
        "text": "晉楚更霸　趙魏困橫"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-073",
        "order": 73,
        "source_block_chunk": 1,
        "source_block_order": 73,
        "text": "假途滅虢　踐土會盟"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-074",
        "order": 74,
        "source_block_chunk": 1,
        "source_block_order": 74,
        "text": "何遵約法　韓弊煩刑"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-075",
        "order": 75,
        "source_block_chunk": 1,
        "source_block_order": 75,
        "text": "起翦頗牧　用軍最精"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-076",
        "order": 76,
        "source_block_chunk": 1,
        "source_block_order": 76,
        "text": "宣威沙漠　馳譽丹青"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-077",
        "order": 77,
        "source_block_chunk": 1,
        "source_block_order": 77,
        "text": "九州禹跡　百郡秦并"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-078",
        "order": 78,
        "source_block_chunk": 1,
        "source_block_order": 78,
        "text": "嶽宗恆岱　禪主云亭"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-079",
        "order": 79,
        "source_block_chunk": 1,
        "source_block_order": 79,
        "text": "雁門紫塞　雞田赤城"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-080",
        "order": 80,
        "source_block_chunk": 1,
        "source_block_order": 80,
        "text": "昆池碣石　鉅野洞庭"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-081",
        "order": 81,
        "source_block_chunk": 1,
        "source_block_order": 81,
        "text": "曠遠緜邈　巖岫杳冥"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-082",
        "order": 82,
        "source_block_chunk": 1,
        "source_block_order": 82,
        "text": "治本於農　務茲稼穡"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-083",
        "order": 83,
        "source_block_chunk": 1,
        "source_block_order": 83,
        "text": "俶載南畝　我藝黍稷"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-084",
        "order": 84,
        "source_block_chunk": 1,
        "source_block_order": 84,
        "text": "稅熟貢新　勸賞黜陟"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-085",
        "order": 85,
        "source_block_chunk": 1,
        "source_block_order": 85,
        "text": "孟軻敦素　史魚秉直"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-086",
        "order": 86,
        "source_block_chunk": 1,
        "source_block_order": 86,
        "text": "庶幾中庸　勞謙謹敕"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-087",
        "order": 87,
        "source_block_chunk": 1,
        "source_block_order": 87,
        "text": "聆音察理　鑑貌辨色"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-088",
        "order": 88,
        "source_block_chunk": 1,
        "source_block_order": 88,
        "text": "貽厥嘉猷　勉其祗植"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-089",
        "order": 89,
        "source_block_chunk": 1,
        "source_block_order": 89,
        "text": "省躬譏誡　寵增抗極"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-090",
        "order": 90,
        "source_block_chunk": 1,
        "source_block_order": 90,
        "text": "殆辱近恥　林皋幸即"
      },
      {
        "character_count": 8,
        "id": "chapter-001-line-091",
        "order": 91,
        "source_block_chunk": 1,
