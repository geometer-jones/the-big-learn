{
  "chapter": {
    "character_count": 1069,
    "id": "chapter-001",
    "order": 1,
    "reading_unit_count": 86,
    "reading_units": [
      {
        "character_count": 12,
        "id": "chapter-001-line-001",
        "order": 1,
        "source_block_chunk": 1,
        "source_block_order": 1,
        "text": "人之初，性本善。性相近，習相遠。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-002",
        "order": 2,
        "source_block_chunk": 1,
        "source_block_order": 2,
        "text": "苟不教，性乃遷。教之道，貴以專。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-003",
        "order": 3,
        "source_block_chunk": 1,
        "source_block_order": 3,
        "text": "昔孟母，擇鄰處。子不學，斷機杼。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-004",
        "order": 4,
        "source_block_chunk": 1,
        "source_block_order": 4,
        "text": "竇燕山，有義方。教五子，名俱揚。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-005",
        "order": 5,
        "source_block_chunk": 1,
        "source_block_order": 5,
        "text": "養不教，父之過。教不嚴，師之惰。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-006",
        "order": 6,
        "source_block_chunk": 1,
        "source_block_order": 6,
        "text": "子不學，非所宜。幼不學，老何為。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-007",
        "order": 7,
        "source_block_chunk": 1,
        "source_block_order": 7,
        "text": "玉不琢，不成器。人不學，不知義。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-008",
        "order": 8,
        "source_block_chunk": 1,
        "source_block_order": 8,
        "text": "為人子，方少時。親師友，習禮儀。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-009",
        "order": 9,
        "source_block_chunk": 1,
        "source_block_order": 9,
        "text": "香九齡，能溫席。孝於親，所當執。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-010",
        "order": 10,
        "source_block_chunk": 1,
        "source_block_order": 10,
        "text": "融四歲，能讓梨。弟於長，宜先知。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-011",
        "order": 11,
        "source_block_chunk": 1,
        "source_block_order": 11,
        "text": "首孝弟，次見聞。知某數，識某文。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-012",
        "order": 12,
        "source_block_chunk": 1,
        "source_block_order": 12,
        "text": "一而十，十而百。百而千，千而萬。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-013",
        "order": 13,
        "source_block_chunk": 1,
        "source_block_order": 13,
        "text": "三才者，天地人。三光者，日月星。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-014",
        "order": 14,
        "source_block_chunk": 1,
        "source_block_order": 14,
        "text": "三綱者，君臣義。父子親，夫婦順。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-015",
        "order": 15,
        "source_block_chunk": 1,
        "source_block_order": 15,
        "text": "曰春夏，曰秋冬。此四時，運不窮。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-016",
        "order": 16,
        "source_block_chunk": 1,
        "source_block_order": 16,
        "text": "曰南北，曰西東。此四方，應乎中。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-017",
        "order": 17,
        "source_block_chunk": 1,
        "source_block_order": 17,
        "text": "曰水火，木金土。此五行，本乎數。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-018",
        "order": 18,
        "source_block_chunk": 1,
        "source_block_order": 18,
        "text": "曰仁義，禮智信。此五常，不容紊。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-019",
        "order": 19,
        "source_block_chunk": 1,
        "source_block_order": 19,
        "text": "稻粱菽，麥黍稷。此六穀，人所食。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-020",
        "order": 20,
        "source_block_chunk": 1,
        "source_block_order": 20,
        "text": "馬牛羊，雞犬豕。此六畜，人所飼。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-021",
        "order": 21,
        "source_block_chunk": 1,
        "source_block_order": 21,
        "text": "曰喜怒，曰哀懼。愛惡欲，七情具。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-022",
        "order": 22,
        "source_block_chunk": 1,
        "source_block_order": 22,
        "text": "匏土革，木石金。與絲竹，乃八音。"
      },
      {
        "character_count": 25,
        "id": "chapter-001-line-023",
        "order": 23,
        "source_block_chunk": 1,
        "source_block_order": 23,
        "text": "高曾祖，父而身。身而子，子而孫。自子孫，至玄1曾。乃九族，人之倫。"
      },
      {
        "character_count": 30,
        "id": "chapter-001-line-024",
        "order": 24,
        "source_block_chunk": 1,
        "source_block_order": 24,
        "text": "父子恩，夫婦從。兄則友，弟則恭。長幼序，友與朋。君則敬，臣則忠。此十義，人所同。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-025",
        "order": 25,
        "source_block_chunk": 1,
        "source_block_order": 25,
        "text": "凡訓蒙，須講究。詳訓詁，名句讀。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-026",
        "order": 26,
        "source_block_chunk": 1,
        "source_block_order": 26,
        "text": "為學者，必有初。小學終，至四書。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-027",
        "order": 27,
        "source_block_chunk": 1,
        "source_block_order": 27,
        "text": "論語者，二十篇。群弟子，記善言。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-028",
        "order": 28,
        "source_block_chunk": 1,
        "source_block_order": 28,
        "text": "孟子者，七篇止。講道德，說仁義。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-029",
        "order": 29,
        "source_block_chunk": 1,
        "source_block_order": 29,
        "text": "作中庸，子思筆。中不偏，庸不易。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-030",
        "order": 30,
        "source_block_chunk": 1,
        "source_block_order": 30,
        "text": "作大學，乃曾子。自修齊，至平治。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-031",
        "order": 31,
        "source_block_chunk": 1,
        "source_block_order": 31,
        "text": "孝經通，四書熟。如六經，始可讀。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-032",
        "order": 32,
        "source_block_chunk": 1,
        "source_block_order": 32,
        "text": "詩書易，禮春秋。號六經，當講求。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-033",
        "order": 33,
        "source_block_chunk": 1,
        "source_block_order": 33,
        "text": "有連山，有歸藏。有周易，三易詳。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-034",
        "order": 34,
        "source_block_chunk": 1,
        "source_block_order": 34,
        "text": "有典謨，有訓誥。有誓命，書之奧。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-035",
        "order": 35,
        "source_block_chunk": 1,
        "source_block_order": 35,
        "text": "我周公，作周禮。著六官，存治體。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-036",
        "order": 36,
        "source_block_chunk": 1,
        "source_block_order": 36,
        "text": "大小戴，註禮記。述聖言，禮樂備。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-037",
        "order": 37,
        "source_block_chunk": 1,
        "source_block_order": 37,
        "text": "曰國風，曰雅頌。號四詩，當諷詠。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-038",
        "order": 38,
        "source_block_chunk": 1,
        "source_block_order": 38,
        "text": "詩既亡，春秋作。寓褒貶，別善惡。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-039",
        "order": 39,
        "source_block_chunk": 1,
        "source_block_order": 39,
        "text": "三傳者，有公羊。有左氏，有彀梁。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-040",
        "order": 40,
        "source_block_chunk": 1,
        "source_block_order": 40,
        "text": "經既明，方讀子。撮其要，記其事。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-041",
        "order": 41,
        "source_block_chunk": 1,
        "source_block_order": 41,
        "text": "五子者，有荀楊。文中子，及老莊。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-042",
        "order": 42,
        "source_block_chunk": 1,
        "source_block_order": 42,
        "text": "經子通，讀諸史。考世系，知終始。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-043",
        "order": 43,
        "source_block_chunk": 1,
        "source_block_order": 43,
        "text": "自羲農，至黃帝。號三皇，居上世。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-044",
        "order": 44,
        "source_block_chunk": 1,
        "source_block_order": 44,
        "text": "唐有虞，號二帝。相揖遜，稱盛世。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-045",
        "order": 45,
        "source_block_chunk": 1,
        "source_block_order": 45,
        "text": "夏有禹，商有湯。周文王，稱三王。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-046",
        "order": 46,
        "source_block_chunk": 1,
        "source_block_order": 46,
        "text": "夏傳子，家天下。四百載，遷夏社。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-047",
        "order": 47,
        "source_block_chunk": 1,
        "source_block_order": 47,
        "text": "湯伐夏，國號商。六百載，至紂亡。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-048",
        "order": 48,
        "source_block_chunk": 1,
        "source_block_order": 48,
        "text": "周武王，始誅紂。八百載，最長久。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-049",
        "order": 49,
        "source_block_chunk": 1,
        "source_block_order": 49,
        "text": "周轍東，王綱墮。逞干戈，尚游說。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-050",
        "order": 50,
        "source_block_chunk": 1,
        "source_block_order": 50,
        "text": "始春秋，終戰國。五霸強，七雄出。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-051",
        "order": 51,
        "source_block_chunk": 1,
        "source_block_order": 51,
        "text": "嬴秦氏，始兼並。傳二世，楚漢爭。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-052",
        "order": 52,
        "source_block_chunk": 1,
        "source_block_order": 52,
        "text": "高祖興，漢業建。至孝平，王莽篡。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-053",
        "order": 53,
        "source_block_chunk": 1,
        "source_block_order": 53,
        "text": "光武興，為東漢。四百年，終於獻。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-054",
        "order": 54,
        "source_block_chunk": 1,
        "source_block_order": 54,
        "text": "魏蜀吳，爭漢鼎。號三國，迄兩晉。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-055",
        "order": 55,
        "source_block_chunk": 1,
        "source_block_order": 55,
        "text": "宋齊繼，梁陳承。為南朝，都金陵。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-056",
        "order": 56,
        "source_block_chunk": 1,
        "source_block_order": 56,
        "text": "北元魏，分東西。宇文周，興高齊。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-057",
        "order": 57,
        "source_block_chunk": 1,
        "source_block_order": 57,
        "text": "迨至隋，一土宇。不再傳，失統緒。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-058",
        "order": 58,
        "source_block_chunk": 1,
        "source_block_order": 58,
        "text": "唐高祖，起義師。除隋亂，創國基。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-059",
        "order": 59,
        "source_block_chunk": 1,
        "source_block_order": 59,
        "text": "二十傳，三百載。梁滅之，國乃改。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-060",
        "order": 60,
        "source_block_chunk": 1,
        "source_block_order": 60,
        "text": "梁唐晉，及漢周。稱五代，皆有由。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-061",
        "order": 61,
        "source_block_chunk": 1,
        "source_block_order": 61,
        "text": "炎宋興，受周禪。十八傳，南北混。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-062",
        "order": 62,
        "source_block_chunk": 1,
        "source_block_order": 62,
        "text": "十七史，全在茲。載治亂，知興衰。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-063",
        "order": 63,
        "source_block_chunk": 1,
        "source_block_order": 63,
        "text": "讀史書，考實錄。通古今，若親目。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-064",
        "order": 64,
        "source_block_chunk": 1,
        "source_block_order": 64,
        "text": "口而誦，心而惟。朝於斯，夕於斯。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-065",
        "order": 65,
        "source_block_chunk": 1,
        "source_block_order": 65,
        "text": "昔仲尼，師項橐。古聖賢，尚勤學。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-066",
        "order": 66,
        "source_block_chunk": 1,
        "source_block_order": 66,
        "text": "趙中令，讀魯論。彼既仕，學且勤。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-067",
        "order": 67,
        "source_block_chunk": 1,
        "source_block_order": 67,
        "text": "披蒲編，削竹簡。彼無書，且知勉。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-068",
        "order": 68,
        "source_block_chunk": 1,
        "source_block_order": 68,
        "text": "頭懸梁，錐刺股。彼不教，自勤苦。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-069",
        "order": 69,
        "source_block_chunk": 1,
        "source_block_order": 69,
        "text": "如囊螢，如映雪。家雖貧，學不綴。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-070",
        "order": 70,
        "source_block_chunk": 1,
        "source_block_order": 70,
        "text": "如負薪，如掛角。身雖勞，猶苦卓。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-071",
        "order": 71,
        "source_block_chunk": 1,
        "source_block_order": 71,
        "text": "蘇老泉，二十七。始發憤，讀書籍。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-072",
        "order": 72,
        "source_block_chunk": 1,
        "source_block_order": 72,
        "text": "彼既老，猶悔遲。爾小生，宜早思。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-073",
        "order": 73,
        "source_block_chunk": 1,
        "source_block_order": 73,
        "text": "若梁灝，八十二。對大廷，魁多士。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-074",
        "order": 74,
        "source_block_chunk": 1,
        "source_block_order": 74,
        "text": "彼既成，衆稱異。爾小生，宜立誌。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-075",
        "order": 75,
        "source_block_chunk": 1,
        "source_block_order": 75,
        "text": "瑩八歲，能詠詩。泌七歲，能賦碁。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-076",
        "order": 76,
        "source_block_chunk": 1,
        "source_block_order": 76,
        "text": "彼穎悟，人稱奇。爾幼學，當效之。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-077",
        "order": 77,
        "source_block_chunk": 1,
        "source_block_order": 77,
        "text": "蔡文姬，能辨琴。謝道韞，能詠吟。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-078",
        "order": 78,
        "source_block_chunk": 1,
        "source_block_order": 78,
        "text": "彼女子，且聰敏。爾男子，當自警。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-079",
        "order": 79,
        "source_block_chunk": 1,
        "source_block_order": 79,
        "text": "唐劉晏，方七歲。舉神童，作正字。"
      },
      {
        "character_count": 18,
        "id": "chapter-001-line-080",
        "order": 80,
        "source_block_chunk": 1,
        "source_block_order": 80,
        "text": "彼雖幼，身己仕。爾幼學，勉而緻。有為者，亦若是。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-081",
        "order": 81,
        "source_block_chunk": 1,
        "source_block_order": 81,
        "text": "犬守夜，雞司晨。苟不學，曷為人。"
      },
      {
        "character_count": 12,
        "id": "chapter-001-line-082",
        "order": 82,
        "source_block_chunk": 1,
        "source_block_order": 82,
        "text": "蠶吐絲，蜂釀蜜。人不學，不如物。"
      },
      {
        "character_count": 12,
