{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-big-learn.local/annotations/schema/line-record.schema.json",
  "title": "The Big Learn Line Record",
  "description": "Canonical six-layer record for a single annotated line, plus optional phrase-level segments.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "work",
    "source_variant",
    "section",
    "order",
    "annotation_profile",
    "layers",
    "provenance",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "work": {
      "type": "string",
      "description": "Canonical work identifier, for example da-xue."
    },
    "source_variant": {
      "type": "string",
      "description": "Textual edition or editorial variant used for this line."
    },
    "section": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "minimum": 1
    },
    "annotation_profile": {
      "type": "string",
      "enum": [
        "modern-mandarin-reading"
      ],
      "description": "Pronunciation profile used for pinyin and zhuyin."
    },
    "layers": {
      "$ref": "#/$defs/layerBundle"
    },
    "segments": {
      "type": "array",
      "description": "Optional phrase-level segments for flashcard derivation and gloss alignment.",
      "items": {
        "$ref": "#/$defs/segment"
      }
    },
    "character_glosses_en": {
      "type": "array",
      "description": "Optional per-character English definitions aligned to the simplified line, either including punctuation slots or only non-punctuation characters. Each string should be a dictionary-style gloss for the character in isolation, using semicolons when listing multiple senses.",
      "items": {
        "type": "string"
      }
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "author",
        "source_url"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "canonical"
      ]
    }
  },
  "$defs": {
    "layerBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "traditional",
        "simplified",
        "zhuyin",
        "pinyin",
        "gloss_en",
        "translation_en"
      ],
      "properties": {
        "traditional": {
          "type": "string"
        },
        "simplified": {
          "type": "string"
        },
        "zhuyin": {
          "type": "string"
        },
        "pinyin": {
          "type": "string"
        },
        "gloss_en": {
          "type": "string"
        },
        "translation_en": {
          "type": "string"
        }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "traditional",
        "simplified",
        "zhuyin",
        "pinyin",
        "gloss_en"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "traditional": {
          "type": "string"
        },
        "simplified": {
          "type": "string"
        },
        "zhuyin": {
          "type": "string"
        },
        "pinyin": {
          "type": "string"
        },
        "gloss_en": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
